        layout.addStretch()

        self.setLayout(layout)

        # Signal
        self.apply_btn.clicked.connect(self.apply_settings)
        self.reset_btn.clicked.connect(self.reset_form)
        self.restore_btn.clicked.connect(self.restore_defaults)
        self.help_btn.clicked.connect(self.show_help)
        self.saveall_btn.clicked.connect(self.save_settings)
        self.yes_btn.clicked.connect(self.confirm_settings)

        self.set_defaults()

    def set_defaults(self):
        self.admin_name.setText(self.default_admin)
        self.mode_combo.setCurrentText(self.default_mode)
        self.security_combo.setCurrentText(self.default_security)

    def apply_settings(self):
        info = (f"Admin: {self.admin_name.text()}\n"
                f"Rejim: {self.mode_combo.currentText()}\n"
                f"Xavfsizlik: {self.security_combo.currentText()}")
        QMessageBox.information(self, "Apply", info)

    def reset_form(self):
        self.admin_name.clear()
        self.mode_combo.setCurrentIndex(0)
        self.security_combo.setCurrentIndex(1)
        QMessageBox.information(self, "Reset", "Forma tozalandi!")

    def restore_defaults(self):
        self.set_defaults()
        QMessageBox.information(self, "RestoreDefaults", "Standart qiymatlar tiklandi!")

    def show_help(self):
        QMessageBox.information(self, "Help",
                                "Admin sozlamalari paneli:\n\n"
                                "• Apply: Joriy sozlamalarni ko'rsatadi\n"
                                "• Reset: Barcha maydonlarni tozalaydi\n"
                                "• RestoreDefaults: Standart qiymatlarni tiklaydi\n"
                                "• SaveAll: Sozlamalarni faylga saqlaydi\n"
                                "• Yes: Sozlamalarni tasdiqlaydi")

    def save_settings(self):
        data = {
            'admin_name': self.admin_name.text(),
            'mode': self.mode_combo.currentText(),
            'security': self.security_combo.currentText()
        }
        with open('admin_settings.json', 'w', encoding='utf-8') as f:
            json.dump(data, f, indent=2, ensure_ascii=False)
        QMessageBox.information(self, "SaveAll", "Sozlamalar saqlandi!")

    def confirm_settings(self):
        if self.admin_name.text():
            QMessageBox.information(self, "Yes", "Sozlamalar tasdiqlandi!")
        else:
            QMessageBox.warning(self, "Xato", "Admin nomini kiriting!")


