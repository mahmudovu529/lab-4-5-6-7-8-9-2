# ==================== 1-vazifa: Foydalanuvchi ro'yxatdan o'tishi ====================
class Task1_Registration(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("1-vazifa: Foydalanuvchi Ro'yxatdan O'tishi")
        self.setFixedSize(450, 400)

        # Maydonlar
        self.firstname_input = QLineEdit()
        self.firstname_input.setPlaceholderText("Ismingizni kiriting")

        self.lastname_input = QLineEdit()
        self.lastname_input.setPlaceholderText("Familiyangizni kiriting")

        self.login_input = QLineEdit()
        self.login_input.setPlaceholderText("Loginingizni kiriting")

        self.password_input = QLineEdit()
        self.password_input.setPlaceholderText("Parolingizni kiriting")
        self.password_input.setEchoMode(QLineEdit.Password)

        # Tugmalar
        self.apply_btn = QPushButton("Apply")
        self.reset_btn = QPushButton("Reset")
        self.saveall_btn = QPushButton("SaveAll")
        self.yes_btn = QPushButton("Yes")

        # Layout
        layout = QVBoxLayout()

        form_group = QGroupBox("Ro'yxatdan o'tish formasi")
        form_layout = QVBoxLayout()
        form_layout.addWidget(QLabel("Ism:"))
        form_layout.addWidget(self.firstname_input)
        form_layout.addWidget(QLabel("Familiya:"))
        form_layout.addWidget(self.lastname_input)
        form_layout.addWidget(QLabel("Login:"))
        form_layout.addWidget(self.login_input)
        form_layout.addWidget(QLabel("Parol:"))
        form_layout.addWidget(self.password_input)
        form_group.setLayout(form_layout)

        btn_layout = QHBoxLayout()
        btn_layout.addWidget(self.apply_btn)
        btn_layout.addWidget(self.reset_btn)
        btn_layout.addWidget(self.saveall_btn)
        btn_layout.addWidget(self.yes_btn)

        layout.addWidget(form_group)
        layout.addLayout(btn_layout)
        layout.addStretch()

        self.setLayout(layout)

        # Signal
        self.apply_btn.clicked.connect(self.apply_data)
        self.reset_btn.clicked.connect(self.reset_form)
        self.saveall_btn.clicked.connect(self.save_all)
        self.yes_btn.clicked.connect(self.confirm_registration)

    def apply_data(self):
        data = f"Ism: {self.firstname_input.text()}\nFamiliya: {self.lastname_input.text()}\nLogin: {self.login_input.text()}\nParol: {'*' * len(self.password_input.text())}"
        QMessageBox.information(self, "Ma'lumotlar", data)

    def reset_form(self):
        self.firstname_input.clear()
        self.lastname_input.clear()
        self.login_input.clear()
        self.password_input.clear()
        QMessageBox.information(self, "Reset", "Forma tozalandi!")

    def save_all(self):
        data = {
            'firstname': self.firstname_input.text(),
            'lastname': self.lastname_input.text(),
            'login': self.login_input.text(),
            'password': self.password_input.text()
        }
        with open('users.json', 'a', encoding='utf-8') as f:
            json.dump(data, f)
            f.write('\n')
        QMessageBox.information(self, "SaveAll", "Ma'lumotlar saqlandi!")

    def confirm_registration(self):
        if all([self.firstname_input.text(), self.lastname_input.text(),
                self.login_input.text(), self.password_input.text()]):
            QMessageBox.information(self, "Yes", "Ro'yxatdan o'tish tasdiqlandi!")
        else:
            QMessageBox.warning(self, "Xato", "Barcha maydonlarni to'ldiring!")


