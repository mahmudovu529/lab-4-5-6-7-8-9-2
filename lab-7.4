import sys
from PyQt5.QtWidgets import (
    QApplication, QMainWindow, QLabel, QAction, QMessageBox,
    QVBoxLayout, QWidget
)
from PyQt5.QtCore import Qt


class LibraryManagement(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Kutubxona Boshqaruv Tizimi")
        self.setGeometry(200, 200, 700, 500)

        # Markaziy widget va label
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        layout = QVBoxLayout()
        central_widget.setLayout(layout)

        self.center_label = QLabel("Kutubxona boshqaruv tizimiga xush kelibsiz!")
        self.center_label.setAlignment(Qt.AlignCenter)
        self.center_label.setStyleSheet("""
            font-size: 24px;
            font-weight: bold;
            color: #2c3e50;
            padding: 30px;
            background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                stop:0 #3498db, stop:1 #2980b9);
            color: white;
            border-radius: 15px;
            margin: 20px;
        """)
        layout.addWidget(self.center_label)

        # Menyu yaratish
        self.create_menus()

        # Status bar
        self.statusBar().showMessage("Kutubxona tizimi tayyor | Menyudan biror bo'limni tanlang")

        # Styling
        self.setStyleSheet("""
            QMainWindow {
                background-color: #ecf0f1;
            }
            QMenuBar {
                background-color: #2c3e50;
                color: white;
                font-size: 14px;
            }
            QMenuBar::item {
                padding: 8px 15px;
            }
            QMenuBar::item:selected {
                background-color: #34495e;
            }
            QMenu {
                background-color: white;
                color: #2c3e50;
            }
        """)

    def create_menus(self):
        menubar = self.menuBar()

        # Kitoblar menyusi
        books_menu = menubar.addMenu("📚 Kitoblar")

        view_books_action = QAction("Barcha kitoblar", self)
        view_books_action.triggered.connect(self.show_books)
        books_menu.addAction(view_books_action)

        add_book_action = QAction("Yangi kitob qo'shish", self)
        add_book_action.triggered.connect(self.add_book)
        books_menu.addAction(add_book_action)

        search_book_action = QAction("Kitob qidirish", self)
        search_book_action.triggered.connect(self.search_book)
        books_menu.addAction(search_book_action)

        books_menu.addSeparator()

        borrowed_books_action = QAction("Berilgan kitoblar", self)
        borrowed_books_action.triggered.connect(self.borrowed_books)
        books_menu.addAction(borrowed_books_action)

        # O'quvchilar menyusi
        students_menu = menubar.addMenu("👨‍🎓 O'quvchilar")

        view_students_action = QAction("Barcha o'quvchilar", self)
        view_students_action.triggered.connect(self.show_students)
        students_menu.addAction(view_students_action)

        add_student_action = QAction("Yangi o'quvchi qo'shish", self)
        add_student_action.triggered.connect(self.add_student)
        students_menu.addAction(add_student_action)

        search_student_action = QAction("O'quvchi qidirish", self)
        search_student_action.triggered.connect(self.search_student)
        students_menu.addAction(search_student_action)

        students_menu.addSeparator()

        debts_action = QAction("Qarzdor o'quvchilar", self)
        debts_action.triggered.connect(self.show_debts)
        students_menu.addAction(debts_action)

        # Yordam menyusi
        help_menu = menubar.addMenu("❓ Yordam")

        about_action = QAction("Dastur haqida", self)
        about_action.triggered.connect(self.show_about)
        help_menu.addAction(about_action)

        help_action = QAction("Yordam", self)
        help_action.setShortcut("F1")
        help_action.triggered.connect(self.show_help)
        help_menu.addAction(help_action)

        user_guide_action = QAction("Foydalanuvchi qo'llanmasi", self)
        user_guide_action.triggered.connect(self.show_user_guide)
        help_menu.addAction(user_guide_action)

    def update_label(self, title, message):
        self.center_label.setText(f"{title}\n\n{message}")
        self.statusBar().showMessage(title, 3000)

    # Kitoblar bo'limi
    def show_books(self):
        self.update_label(
            "📚 BARCHA KITOBLAR",
            "1. Python dasturlash asoslari\n"
            "2. C++ dasturlash tili\n"
            "3. Ma'lumotlar tuzilmasi\n"
            "4. Web dasturlash\n"
            "5. Sun'iy intellekt"
        )

    def add_book(self):
        self.update_label(
            "➕ YANGI KITOB QO'SHISH",
            "Yangi kitob qo'shish formasi:\n\n"
            "Kitob nomi: ______\n"
            "Muallif: ______\n"
            "Janr: ______\n"
            "Yil: ______\n\n"
            "(Bu yerda real forma bo'lishi mumkin)"
        )

    def search_book(self):
        self.update_label(
            "🔍 KITOB QIDIRISH",
            "Kitob qidirish:\n\n"
            "Qidiruv so'zini kiriting: ______\n\n"
            "Natijalar:\n"
            "- Python dasturlash\n"
            "- Python web dasturlash"
        )

    def borrowed_books(self):
        self.update_label(
            "📖 BERILGAN KITOBLAR",
            "Hozirda berilgan kitoblar:\n\n"
            "1. 'Python dasturlash' - Ali Valiyev (20.03.2026)\n"
            "2. 'C++ dasturlash' - Sarvar Ahmedov (22.03.2026)\n"
            "3. 'Web dasturlash' - Nilufar Rahimova (25.03.2026)"
        )

    # O'quvchilar bo'limi
    def show_students(self):
        self.update_label(
            "👨‍🎓 BARCHA O'QUVCHILAR",
            "Ro'yxatdagi o'quvchilar:\n\n"
            "1. Ali Valiyev - 001\n"
            "2. Sarvar Ahmedov - 002\n"
            "3. Nilufar Rahimova - 003\n"
            "4. Dilnoza Karimova - 004\n"
            "5. Jahongir Toshmatov - 005"
        )

    def add_student(self):
        self.update_label(
            "➕ YANGI O'QUVCHI QO'SHISH",
            "Yangi o'quvchi qo'shish formasi:\n\n"
            "Ism: ______\n"
            "Familiya: ______\n"
            "Guruh: ______\n"
            "Telefon: ______\n\n"
            "(Bu yerda real forma bo'lishi mumkin)"
        )

    def search_student(self):
        self.update_label(
            "🔍 O'QUVCHI QIDIRISH",
            "O'quvchi qidirish:\n\n"
            "Ism yoki ID raqam: ______\n\n"
            "Natija:\n"
            "Ali Valiyev - ID: 001\n"
            "Guruh: 101 - Telefon: +998901234567"
        )

    def show_debts(self):
        self.update_label(
            "💰 QARZDOR O'QUVCHILAR",
            "Kitob qaytarmagan o'quvchilar:\n\n"
            "1. Ali Valiyev - 'Python dasturlash' (20 kun)\n"
            "2. Sarvar Ahmedov - 'C++ dasturlash' (15 kun)\n\n"
            "Jami qarzdorlar: 2 kishi"
        )

    # Yordam bo'limi
    def show_about(self):
        QMessageBox.about(
            self,
            "Kutubxona Boshqaruv Tizimi",
            "📚 Kutubxona boshqaruv tizimi\n"
            "Versiya: 2.0\n\n"
            "Muallif: PyQt5 Developer\n"
            "© 2026 Barcha huquqlar himoyalangan\n\n"
            "Bu tizim kutubxona faoliyatini\n"
            "samarali boshqarish uchun mo'ljallangan."
        )

    def show_help(self):
        QMessageBox.information(
            self,
            "Yordam",
            "📖 YORDAM MA'LUMOTI\n\n"
            "1. Kitoblar menyusi:\n"
            "   - Barcha kitoblarni ko'rish\n"
            "   - Yangi kitob qo'shish\n"
            "   - Kitob qidirish\n"
            "   - Berilgan kitoblar ro'yxati\n\n"
            "2. O'quvchilar menyusi:\n"
            "   - Barcha o'quvchilarni ko'rish\n"
            "   - Yangi o'quvchi qo'shish\n"
            "   - O'quvchi qidirish\n"
            "   - Qarzdorlar ro'yxati\n\n"
            "3. Yordam menyusi:\n"
            "   - Dastur haqida\n"
            "   - Yordam\n"
            "   - Foydalanuvchi qo'llanmasi"
        )

    def show_user_guide(self):
        QMessageBox.information(
            self,
            "Foydalanuvchi qo'llanmasi",
            "📘 FOYDALANUVCHI QO'LLANMASI\n\n"
            "Asosiy funksiyalar:\n\n"
            "• Kitob qo'shish va boshqarish\n"
            "• O'quvchilarni ro'yxatga olish\n"
            "• Kitob berish va qaytarish\n"
            "• Qarzdorlikni nazorat qilish\n\n"
            "Qo'shimcha ma'lumot uchun:\n"
            "Email: support@library.uz\n"
            "Tel: +998 71 123-45-67"
        )


if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = LibraryManagement()
    window.show()
    sys.exit(app.exec_())
